/* USER CODE BEGIN PD */



/*
 * ======== Porting Config ========
 * 这一区域专门放“和硬件、协议、控制参数相关”的配置。
 *
 * 以后如果要修改：
 * 1. OpenMV 分辨率
 * 2. 舵机方向
 * 3. 舵机机械限位
 * 4. 跟随快慢
 * 5. 中心死区
 * 都优先改这里，不要直接去改下面主逻辑。
 *
 * 这样做的目的就是提高可移植性和后续维护性。
 */

/* =========================================================
 * 1. OpenMV 图像范围配置
 * =========================================================
 * 当前 OpenMV 端使用的是 QVGA(320x240)，并发送目标中心点坐标：
 * X: 0~319
 * Y: 0~239
 *
 * 如果以后改成 QQVGA / VGA / 其他分辨率，
 * 只需要改这里即可。
 */
#define IMAGE_MAX_X                 320.0f
#define IMAGE_MAX_Y                 240.0f

#define IMAGE_CENTER_X              (IMAGE_MAX_X * 0.5f)
#define IMAGE_CENTER_Y              (IMAGE_MAX_Y * 0.5f)

/* =========================================================
 * 2. 舵机通道配置
 * =========================================================
 * 当前使用 TIM2 的两个 PWM 通道：
 * X 轴（水平） -> TIM2_CH1
 * Y 轴（俯仰） -> TIM2_CH2
 *
 * 如果以后换定时器或者换引脚，
 * 优先改这里，并同步检查 CubeMX 对应 PWM 配置。
 */
#define SERVO_X_CHANNEL             TIM_CHANNEL_1
#define SERVO_Y_CHANNEL             TIM_CHANNEL_2

/* =========================================================
 * 3. 舵机角度与脉宽配置
 * =========================================================
 * SERVO_FULL_ANGLE_DEG：
 * 普通 180 度舵机通常保持 180.0f 即可。
 *
 * SERVO_PULSE_MIN_US / MAX_US：
 * 按舵机手册修改脉宽范围。
 * 常见值为 1000~2000us，也有些舵机是 500~2500us。
 */
#define SERVO_FULL_ANGLE_DEG        180.0f
#define SERVO_PULSE_MIN_US          1000.0f
#define SERVO_PULSE_MAX_US          2000.0f

/* =========================================================
 * 4. X / Y 两轴的机械安全角度范围
 * =========================================================
 * 这里的目的不是“让舵机能转满 180 度”，
 * 而是避免云台撞到机械极限。
 *
 * 如果后续发现某个方向快撞到结构件，
 * 直接改对应轴的 MIN / MAX 即可。
 */
#define SERVO_X_MIN_ANGLE           20.0f
#define SERVO_X_MAX_ANGLE           160.0f
#define SERVO_X_START_ANGLE         90.0f

#define SERVO_Y_MIN_ANGLE           10.0f
#define SERVO_Y_MAX_ANGLE           170.0f
#define SERVO_Y_START_ANGLE         90.0f

/* =========================================================
 * 5. 输入滤波参数
 * =========================================================
 * 作用：
 * 对 OpenMV 发来的 X / Y 坐标做低通滤波，
 * 防止识别框轻微抖动时，舵机跟着乱抖。
 *
 * 范围：0~1
 * 越小：越稳，但响应更慢
 * 越大：越灵敏，但更容易抖
 */
#define X_FILTER_FACTOR             0.55f
#define Y_FILTER_FACTOR             0.55f

/* =========================================================
 * 6. 云台平滑输出参数
 * =========================================================
 * SERVO_SMOOTH_FACTOR：
 * 舵机角度平滑系数，范围 0~1
 * 越小：动作更柔和，但会更慢
 * 越大：动作更跟手，但可能更抖
 *
 * SERVO_DEAD_BAND：
 * 角度死区，单位“度”
 * 当前角度距离目标角度足够近时，直接认为到位，
 * 防止舵机在很小范围内不停修正。
 *
 * SERVO_UPDATE_DELAY_MS：
 * 控制循环更新周期。
 */
#define SERVO_SMOOTH_FACTOR         0.40f
#define SERVO_DEAD_BAND             0.20f
#define SERVO_UPDATE_DELAY_MS       5

/* =========================================================
 * 7. 丢目标保持时间（预留）
 * =========================================================
 * 作用：
 * OpenMV 可能会出现短暂漏检。
 * 如果一丢目标就立刻停住，云台会显得很生硬。     
 * 当前版本搜索逻辑已改为“目标有效/无效”直接切换，
 * 本参数暂未参与主控制逻辑，保留用于后续扩展
 * 所以这里设置一个“短暂保持时间”。
 */
 //    #define TRACK_HOLD_MS               300U

/* =========================================================
 * 8. X 轴（水平）跟随参数
 * =========================================================
 * X_CENTER_MIN / MAX：
 * 图像中心附近的允许区间。
 * 当目标进入这个范围时，认为“基本居中”，
 * X 轴不再继续修正。
 *
 * X_TRACK_STEP_GAIN_DEG：
 * 每次根据误差修正的角度步进增益。
 * 越大：追得更快
 * 越小：更稳，但更慢
 *
 * X_TRACK_DIRECTION：
 * 如果发现目标在左边，舵机却往反方向转，
 * 只需要把 1.0f 和 -1.0f 对调，不用改下面逻辑。
 */
#define X_CENTER_MIN                158.0f
#define X_CENTER_MAX                162.0f
#define X_TRACK_STEP_GAIN_DEG       15.0f
#define X_TRACK_DIRECTION           (-1.0f)

/* =========================================================
 * 9. Y 轴（俯仰）跟随参数
 * =========================================================
 * 当前 QVGA 高度是 240，所以中心大约在 120。
 *
 * 如果发现：
 * 目标在画面上方，舵机却继续往下转
 * 或者
 * 目标在画面下方，舵机却继续往上转
 * 那么只改 Y_TRACK_DIRECTION 即可。
 */
#define Y_CENTER_MIN                118.0f
#define Y_CENTER_MAX                122.0f
#define Y_TRACK_STEP_GAIN_DEG       12.0f
#define Y_TRACK_DIRECTION           (1.0f)

/* =========================================================
 * 10. 目标模式定义
 * =========================================================
 * 这里统一管理“当前识别哪个目标”。
 * 后续如果要增加类别，优先改这里。
 */
#define TARGET_MODE_TOILET          0
#define TARGET_MODE_EXIT            1
#define TARGET_MODE_OFFICE          2
#define TARGET_MODE_STAIRS          3
#define TARGET_MODE_ELEVATOR        4
#define TARGET_MODE_EXTINGUISHER    5
#define TARGET_MODE_NONE            6

/* 当前总模式数 */
#define TARGET_MODE_COUNT           7

/* =========================================================
 * 11. 五个独立按钮引脚定义
 * =========================================================
 * 当前按键采用“上拉输入”方式：
 * 松开 = 高电平
 * 按下 = 低电平
 *
 * 后续如果换引脚，只改这里即可。
 */
#define KEY_PERSON_PORT             GPIOC
#define KEY_PERSON_PIN              GPIO_PIN_0

#define KEY_BOTTLE_PORT             GPIOC
#define KEY_BOTTLE_PIN              GPIO_PIN_1

#define KEY_PEN_PORT                GPIOE
#define KEY_PEN_PIN                 GPIO_PIN_13

#define KEY_STAIRS_PORT             GPIOE
#define KEY_STAIRS_PIN              GPIO_PIN_2

#define KEY_ELEVATOR_PORT           GPIOE
#define KEY_ELEVATOR_PIN            GPIO_PIN_3

#define KEY_EXTINGUISHER_PORT       GPIOE
#define KEY_EXTINGUISHER_PIN        GPIO_PIN_7

/* PE14 当前固定用作 DFPlayer 测试按键 */
#define KEY_VOICE_PORT              GPIOE
#define KEY_VOICE_PIN               GPIO_PIN_14

#define KEY_NONE_PORT               GPIOE
#define KEY_NONE_PIN                GPIO_PIN_15

/* =========================================================
 * 12. 按键消抖时间
 * =========================================================
 * 单位：ms
 * 如果后续发现按一下会触发两次，可以适当调大。
 */
#define KEY_DEBOUNCE_MS             180U

/* =========================================================
 * 13. DFPlayer 测试版配置
 * =========================================================
 * 当前只做最小可用测试：
 * 1. 上电后只初始化模块，不自动播放
 * 2. 通过 PE14 按键测试 MP3 文件的播放、暂停、继续
 * 3. 当前 0001.mp3 与“厕所模式”语音共用，便于先验证整条语音链路
 *
 * 后续如果要调整：
 * 1. 默认音量
 * 2. 模式与状态播报文件编号
 * 3. 测试按键使用的文件编号
 * 4. 模块上电等待时间
 * 优先修改这里即可。
 */
#define DFPLAYER_DEFAULT_VOLUME     15U
#define DFPLAYER_MODE_TOILET_MP3_INDEX   1U
#define DFPLAYER_MODE_EXIT_MP3_INDEX     2U
#define DFPLAYER_MODE_OFFICE_MP3_INDEX   3U
#define DFPLAYER_MODE_STAIRS_MP3_INDEX   0U
#define DFPLAYER_MODE_ELEVATOR_MP3_INDEX 0U
#define DFPLAYER_MODE_EXTINGUISHER_MP3_INDEX 0U
#define DFPLAYER_SEARCHING_MP3_INDEX     4U
#define DFPLAYER_TARGET_FOUND_MP3_INDEX  5U
#define DFPLAYER_MODE_NONE_MP3_INDEX     6U
#define DFPLAYER_TARGET_LOST_MP3_INDEX   7U
#define DFPLAYER_TEST_MP3_INDEX          DFPLAYER_MODE_TOILET_MP3_INDEX
#define DFPLAYER_STARTUP_DELAY_MS   2500U
#define DFPLAYER_INIT_RETRY_DELAY_MS 200U
#define DFPLAYER_INIT_RETRY_COUNT   2U

/* =========================================================
 * DFPlayer 系统语音保护参数
 * =========================================================
 * VOICE_MODE_GUARD_MS   : 模式切换语音后的保护时间
 *                         防止“搜索/发现目标”语音抢播模式语音
 *
 * VOICE_STATUS_GUARD_MS : 状态语音之间的最小间隔
 *                         防止“正在搜索目标”和“已发现目标”连续抢播
 *
 * VOICE_FOUND_CONFIRM_MS: “已发现目标”语音的确认时间
 *                         只有目标连续稳定存在一段时间，才允许播报
 *
 * VOICE_TARGET_PROMPT_DELAY_MS:
 *                         “已发现目标”播出后，等待多久再播目标名称语音
 *                         当前适当留长，保证“已发现目标”能完整播完
 *                         这段时间内云台仍可继续做平滑校准
 *
 * VOICE_LOST_PROMPT_DELAY_MS:
 *                         “目标丢失”播出后的保护时间
 *                         当前按 0007.mp3 约 3 秒时长预留一点余量
 *
 * VOICE_MODE_SWITCH_SEARCH_ONLY_MS:
 *                         按键切换目标后的“只允许寻找”保护时间
 *                         这段时间内不播“已找到”和“目标丢失”
 */
#define VOICE_MODE_GUARD_MS         1800U
#define VOICE_STATUS_GUARD_MS       1200U
#define VOICE_FOUND_CONFIRM_MS      700U
#define VOICE_TARGET_PROMPT_DELAY_MS 3600U
#define VOICE_LOST_PROMPT_DELAY_MS  3200U
#define VOICE_MODE_SWITCH_SEARCH_ONLY_MS 1200U
#define SEARCH_DIRECTION_EPSILON_PIXELS 5.0f

/* 系统语音待播类型 */
#define VOICE_PROMPT_TYPE_NONE      0U
#define VOICE_PROMPT_TYPE_SEARCH    1U
#define VOICE_PROMPT_TYPE_FOUND     2U
#define VOICE_PROMPT_TYPE_TARGET    3U


/* =========================================================
 * 14. 搜索模式参数（主动寻找目标）
 * =========================================================
 * 作用：
 * 当系统当前没有检测到目标时，
 * 云台自动执行左右扫描，以扩大视野范围，
 * 从而重新获取目标。
 *
 * 扫描方式：
 * 中心 → 左 → 右 → 左（往返扫描）
 *
 * SEARCH_X_LEFT_ANGLE / RIGHT：
 * 控制扫描的左右范围（不要太大，避免撞结构）
 *
 * SEARCH_STEP_DEG：
 * 每次扫描步进角度（越大越快，越小越平滑）
 *
 * SEARCH_UPDATE_MS：
 * 扫描更新周期（影响扫描速度）
 *
 * SEARCH_START_DELAY_MS：
 * 切换目标后，先回中等待一段时间再开始扫描，
 * 防止刚切换时画面还没稳定就开始乱扫。
 */
#define SEARCH_X_LEFT_ANGLE         25.0f
#define SEARCH_X_RIGHT_ANGLE        160.0f
#define SEARCH_Y_FIXED_ANGLE        90.0f
#define SEARCH_STEP_DEG             1.2f
#define SEARCH_UPDATE_MS            25U
#define SEARCH_START_DELAY_MS       800U

/* =========================================================
 * 15. 自适应主动重捕获参数
 * =========================================================
 * 说明：
 * 1. 仅在“已经稳定跟踪过目标、随后又真正丢失”时启用
 * 2. 阶段 1 为局部快速搜索，阶段 2 为全范围扩展搜索
 * 3. 按键切换后的普通搜索仍沿用上面的基础搜索参数
 */
#define SEARCH_PHASE_NONE                   0U
#define SEARCH_PHASE_LOCAL_RECAPTURE        1U
#define SEARCH_PHASE_GLOBAL_RECAPTURE       2U

#define SEARCH_PHASE1_BASE_AMPLITUDE_DEG    10.0f
#define SEARCH_PHASE1_ERROR_GAIN_DEG        10.0f
#define SEARCH_PHASE1_TIME_GAIN_DEG_PER_S   4.0f
#define SEARCH_PHASE1_MIN_AMPLITUDE_DEG     8.0f
#define SEARCH_PHASE1_MAX_AMPLITUDE_DEG     26.0f
#define SEARCH_PHASE1_STEP_DEG              1.8f
#define SEARCH_PHASE1_UPDATE_MS             18U
#define SEARCH_PHASE1_TIMEOUT_MS            1800U

#define SEARCH_PHASE2_STEP_BASE_DEG         1.2f
#define SEARCH_PHASE2_STEP_GAIN_DEG_PER_S   0.4f
#define SEARCH_PHASE2_STEP_MIN_DEG          1.2f
#define SEARCH_PHASE2_STEP_MAX_DEG          2.4f
#define SEARCH_PHASE2_LEFT_ANGLE            SERVO_X_MIN_ANGLE
#define SEARCH_PHASE2_RIGHT_ANGLE           SERVO_X_MAX_ANGLE

/* =========================================================
 * 16. 丢失缓冲参数
 * =========================================================
 * 作用：
 * 防止 OpenMV 短暂漏检导致系统频繁进入搜索模式。
 *
 * LOST_COUNT_MAX：
 * 连续多少帧没有检测到目标，才认为真正丢失。
 */
#define TARGET_LOST_HOLD_MS         1200U
#define LOST_COUNT_MAX              5

/* USER CODE END PD */

/* Private macro -------------------------------------------------------------*/
/* USER CODE BEGIN PM */

/* USER CODE END PM */

/* Private variables ---------------------------------------------------------*/
I2C_HandleTypeDef hi2c1;

TIM_HandleTypeDef htim2;

UART_HandleTypeDef huart1;
UART_HandleTypeDef huart2;

/* USER CODE BEGIN PV */

    /* =========================================================
     * DFPlayer 测试状态变量
     * =========================================================
     * voice_started : 是否已经执行过首次播放
     * voice_paused  : 当前是否处于“暂停”而非“播放”状态
     */
    uint8_t voice_started = 0;
    uint8_t voice_paused = 0;

    /* =========================================================
     * 系统语音状态变量
     * =========================================================
     * prev_search_mode             : 上一轮循环的搜索状态
     * prev_target_valid            : 上一轮循环的目标有效状态
     * mode_found_prompt_played     : 当前模式下是否已经播过“已发现目标”
     * pending_prompt_valid         : 当前是否存在待播系统语音
     * pending_prompt_index         : 待播语音文件编号
     * pending_prompt_type          : 待播语音类型（搜索/发现/目标名称）
     * pending_prompt_tick          : 待播语音允许播放的时间点
     * system_voice_guard_until_tick: 系统语音保护截止时间
     * found_prompt_candidate_active: 当前是否处于“发现语音确认中”
     * found_prompt_candidate_tick  : 进入确认阶段的起始时间
     * lost_recovery_active         : 当前是否处于“丢失后重新找回”的流程中
     * lost_search_prompt_played    : 丢失恢复流程里是否已经播过一次搜索语音
     * mode_switch_search_only_until_tick:
     *                         按键切换后的“只允许寻找”保护截止时间
     * mode_switch_wait_for_first_found:
     *                         保护期结束后，是否仍需等待第一次有效发现
     */
    uint8_t prev_search_mode = 0;
    uint8_t prev_target_valid = 0;
    uint8_t mode_found_prompt_played = 0;
    uint8_t pending_prompt_valid = 0;
    uint16_t pending_prompt_index = 0;
    uint8_t pending_prompt_type = VOICE_PROMPT_TYPE_NONE;
    uint32_t pending_prompt_tick = 0;
    uint32_t system_voice_guard_until_tick = 0;
    uint8_t found_prompt_candidate_active = 0;
    uint32_t found_prompt_candidate_tick = 0;
    uint8_t lost_recovery_active = 0;
    uint8_t lost_search_prompt_played = 0;
    uint32_t mode_switch_search_only_until_tick = 0;
    uint8_t mode_switch_wait_for_first_found = 0;

    float last_x_error = 0;
    
    uint8_t rx_data;                                    //USART2每次接收字节
    char rx_buffer[100];                                 //存一整行数据 
    uint8_t rx_index = 0;                           //当前接收到的位置
    char tx_buffer[100];                             //USART1 打印用               
    volatile uint8_t uart2_received_flag = 0;         //一帧完成接收标志位
		
		uint8_t search_mode = 0;              // 0: 跟踪模式  1: 搜索模式

    /* =========================================================
      * 搜索阶段控制
      * =========================================================
      * search_phase：
      * 0 -> 普通搜索
      * 1 -> 丢失后的局部重捕获
      * 2 -> 局部失败后的全范围重捕获
      *
      * search_center_x：
      * 记录进入局部重捕获时的中心位置
      */
      uint8_t search_phase = SEARCH_PHASE_NONE;
      float search_center_x = SERVO_X_START_ANGLE;

    float search_angle_x = SERVO_X_START_ANGLE;
    int8_t search_direction = 1;          // 1: 向右扫  -1: 向左扫
    uint32_t search_last_tick = 0;
    uint32_t search_phase_start_tick = 0;
    uint32_t target_switch_tick = 0;
    float search_phase1_left_angle = SERVO_X_START_ANGLE;
    float search_phase1_right_angle = SERVO_X_START_ANGLE;
    float search_phase2_step_deg = SEARCH_PHASE2_STEP_BASE_DEG;

    uint32_t last_valid_target_tick = 0;

		/* =========================================================
 * 目标模式相关变量
 * =========================================================
 * current_target_mode：当前识别模式
 * key_last_tick      ：上一次按键触发时间，用于消抖
 * key_wait_release   ：按键触发后是否仍在等待松手
 */
uint8_t current_target_mode = TARGET_MODE_TOILET;
uint32_t key_last_tick = 0;
uint8_t key_wait_release = 0;

/* =========================================================
 * 目标名称表
 * =========================================================
 * 这里主要用于 OLED 显示。
 * 顺序必须和 TARGET_MODE_xxx 保持一致。
 */
const char *target_mode_name[TARGET_MODE_COUNT] =
{
    "Toilet",
    "Exit",
    "Office",
    "Stairs",
    "Elevator",
    "Exting.",
    "None"
};
		
 /* =========================================================
   * 3. X 轴控制变量
   * =========================================================
   * filtered_x    : 滤波后的 X 坐标
   * x_error       : X 偏差（相对图像中心）
   * current_angle_x : 当前实际输出角度
   * target_angle_x  : 目标角度
   */
  float filtered_x = IMAGE_CENTER_X;
  float x_error = 0.0f;
  float current_angle_x = SERVO_X_START_ANGLE;
  float target_angle_x  = SERVO_X_START_ANGLE;

  /* =========================================================
   * 4. Y 轴控制变量
   * ========================================================= */
  float filtered_y = IMAGE_CENTER_Y;
  float y_error = 0.0f;
  float current_angle_y = SERVO_Y_START_ANGLE;
  float target_angle_y  = SERVO_Y_START_ANGLE;

  /* =========================================================
   * 5. 目标状态变量
   * =========================================================
   * last_target_tick : 最近一次收到有效目标的时间
   * target_valid     : 当前是否处于“检测到目标”的状态
   */
  uint32_t last_target_tick = 0;
  uint8_t target_valid = 0;
		
  /* =========================================================
  * 丢失缓冲计数器
  * =========================================================
  * 作用：
  * 防止 OpenMV 短暂漏检导致云台频繁进入搜索模式。
  *
  */
  uint8_t lost_count = 0;
 




/* USER CODE END PV */

/* Private function prototypes -----------------------------------------------*/
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_USART1_UART_Init(void);
static void MX_I2C1_Init(void);
static void MX_USART2_UART_Init(void);
static void MX_TIM2_Init(void);
/* USER CODE BEGIN PFP */

void Servo_SetAngle(TIM_HandleTypeDef *htim, uint32_t channel, float angle);

/* 用于做浮点数限幅，增强代码可读性和可移植性 */
float Limit_Float(float value, float min, float max);

void Send_TargetMode_To_OpenMV(uint8_t mode);
void Update_TargetMode_Display(uint8_t mode);
uint16_t Get_TargetMode_VoicePrompt(uint8_t mode);
int8_t Get_SearchDirection_FromError(float x_error);
void Reset_AdaptiveRecaptureState(void);
void Enter_AdaptiveRecapturePhase1(uint32_t lost_tick);
void Update_AdaptiveRecaptureWindow(uint32_t now_tick);
void Reset_SystemVoice_State(uint8_t clear_found_prompt_flag);
void Queue_SystemVoice(uint16_t prompt_index, uint8_t prompt_type, uint32_t due_tick);
void Play_SystemVoice_Now(uint16_t prompt_index, uint32_t guard_ms);
void Play_ModeSwitch_Voice(uint8_t mode);
void Handle_SystemVoice_Update(void);
void Handle_Voice_Test_Key(void);
void Key_Scan_And_Handle(void);

/* USER CODE END PFP */

/* Private user code ---------------------------------------------------------*/
/* USER CODE BEGIN 0 */

/* USER CODE END 0 */

/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_USART1_UART_Init();
  MX_I2C1_Init();
  MX_USART2_UART_Init();
  MX_TIM2_Init();
  /* USER CODE BEGIN 2 */

/* =========================================================
   * 1. 启动两个 PWM 通道
   * =========================================================
   * X 轴：TIM2_CH1
   * Y 轴：TIM2_CH2
   *
   * 注意：
   * 这里只是启动 PWM 输出，
   * 前提是 CubeMX 中已经把对应通道配置为 PWM 模式。
   */
  HAL_TIM_PWM_Start(&htim2, SERVO_X_CHANNEL);
  HAL_TIM_PWM_Start(&htim2, SERVO_Y_CHANNEL);

  /* 让两个舵机先回到初始角度，防止上电后位置随机 */
  Servo_SetAngle(&htim2, SERVO_X_CHANNEL, current_angle_x);
  Servo_SetAngle(&htim2, SERVO_Y_CHANNEL, SERVO_Y_START_ANGLE);

  /* OLED 初始化 */
  OLED_Init();
  OLED_Refresh();

  /* 开启 USART2 接收中断，每次接收 1 字节 */
  HAL_UART_Receive_IT(&huart2, &rx_data, 1);

  OLED_Clear();
  OLED_ShowString(0, 0, "N:");
  OLED_Refresh();
  /* =========================================================
   * DFPlayer 测试模块初始化
   * =========================================================
   * 1. 绑定 DFPlayer 使用的串口
   * 2. 等待模块和 TF 卡稳定上电
   * 3. 设置默认音量，但不自动播放
   */
  DFPlayer_Init(&huart1);
  HAL_Delay(DFPLAYER_STARTUP_DELAY_MS);
  for (uint8_t i = 0; i < DFPLAYER_INIT_RETRY_COUNT; i++)
  {
      DFPlayer_SetVolume(DFPLAYER_DEFAULT_VOLUME);
      HAL_Delay(DFPLAYER_INIT_RETRY_DELAY_MS);
  }

  /* =========================================================
   * 2. 目标坐标变量
   * ========================================================= */
  int x = 0, y = 0;                  // 当前解析出的目标坐标
  static int last_x = -1, last_y = -1; // 上一次坐标，用于减少重复处理

 
  /* =========================================================
   * 6. 按键目标选择功能初始化
   * =========================================================
   * 上电默认先选择“厕所”
   * 并把当前模式显示到 OLED，同时发给 OpenMV。
   */
  Update_TargetMode_Display(current_target_mode);
  Send_TargetMode_To_OpenMV(current_target_mode);
	
  /* 切换目标后：云台回中，并进入搜索准备状态 */
  target_angle_x = current_angle_x;
  target_angle_y = SERVO_Y_START_ANGLE;
  search_angle_x = current_angle_x;
  search_direction = 1;
  search_phase = SEARCH_PHASE_NONE;
  search_mode = 1;
  target_switch_tick = HAL_GetTick();
  Reset_AdaptiveRecaptureState();

  /* 同步系统语音状态，避免上电后误触发搜索/发现播报 */
  prev_search_mode = search_mode;
  prev_target_valid = target_valid;
  mode_found_prompt_played = 0;
  pending_prompt_valid = 0;
  pending_prompt_index = 0U;
  pending_prompt_type = VOICE_PROMPT_TYPE_NONE;
  pending_prompt_tick = 0U;
  system_voice_guard_until_tick = 0U;
  found_prompt_candidate_active = 0;
  found_prompt_candidate_tick = 0U;
  lost_search_prompt_played = 0U;

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
while (1)
  {
		    /* =========================================================
     * 0. 按键扫描
     * =========================================================
     * 每次循环先检测按钮是否被按下。
     * 如果按下，则切换当前识别目标，并通知 OpenMV。
     */
    Key_Scan_And_Handle();
		
    /* =========================================================
     * 1. 串口接收完成后，解析 OpenMV 发来的坐标
     * =========================================================
     * OpenMV 发送格式：
     * X:123,Y:45
     *
     * 如果没找到目标，则发送：
     * X:-1,Y:-1
     */
    if (uart2_received_flag)
    {
        uart2_received_flag = 0;

        if (sscanf(rx_buffer, "X:%d,Y:%d", &x, &y) == 2)
        {
      /* -----------------------------
      * 1.1 OpenMV 没找到目标
      * ----------------------------- */
      if (x == -1 && y == -1)
      {
          /* =====================================================
          * 丢失目标处理（时间 + 计数双缓冲）
          * ===================================================== */

          /* 如果刚刚还检测到目标（500ms内），认为是短暂丢失 */
          if ((HAL_GetTick() - last_valid_target_tick) < TARGET_LOST_HOLD_MS)
          {
              /* 什么都不做，保持当前状态 */
          }
          else
          {
              if (search_mode)
              {
                  target_valid = 0;
              }
              else
              {
                  lost_count++;

                  if (lost_count >= LOST_COUNT_MAX)
                  {
                      uint32_t lost_tick = HAL_GetTick();
                      uint8_t mode_switch_guard_active =
                          ((int32_t)(mode_switch_search_only_until_tick - lost_tick) > 0) ? 1U : 0U;
                      uint8_t mode_switch_pending_search =
                          mode_switch_wait_for_first_found ? 1U : 0U;

                      target_valid = 0;
                      search_mode = 1;
                      target_switch_tick = lost_tick;
                      found_prompt_candidate_active = 0;
                      found_prompt_candidate_tick = 0U;
                      pending_prompt_valid = 0;
                      pending_prompt_index = 0U;
                      pending_prompt_type = VOICE_PROMPT_TYPE_NONE;
                      pending_prompt_tick = 0U;

                      if (mode_switch_guard_active || mode_switch_pending_search)
                      {
                          lost_recovery_active = 0;
                          Reset_AdaptiveRecaptureState();
                          search_angle_x = current_angle_x;
                          search_direction = Get_SearchDirection_FromError(last_x_error);
                      }
                      else if (!lost_recovery_active)
                      {
                          lost_recovery_active = 1;
                          Play_SystemVoice_Now(DFPLAYER_TARGET_LOST_MP3_INDEX,
                                               VOICE_LOST_PROMPT_DELAY_MS);
                          Enter_AdaptiveRecapturePhase1(lost_tick);
                      }
                  }
              }
          }
      }

      /* -----------------------------
      * 1.2 OpenMV 找到目标
      * ----------------------------- */
      else
      {
          /* 恢复检测 */
          lost_count = 0;

          target_valid = 1;
          last_target_tick = HAL_GetTick();
          last_valid_target_tick = HAL_GetTick();

          search_mode = 0;
          Reset_AdaptiveRecaptureState();

          if (x != last_x || y != last_y)
          {
              last_x = x;
              last_y = y;

              /* ===== X轴控制 ===== */
              filtered_x = filtered_x * (1.0f - X_FILTER_FACTOR)
                        + ((float)x * X_FILTER_FACTOR);

              x_error = filtered_x - IMAGE_CENTER_X;
              last_x_error = x_error;

              if ((filtered_x >= X_CENTER_MIN) && (filtered_x <= X_CENTER_MAX))
              {
                  target_angle_x = current_angle_x;
              }
              else
              {
                  target_angle_x += (x_error / IMAGE_CENTER_X)
                                  * X_TRACK_STEP_GAIN_DEG
                                  * X_TRACK_DIRECTION;

                  target_angle_x = Limit_Float(target_angle_x,
                                              SERVO_X_MIN_ANGLE,
                                              SERVO_X_MAX_ANGLE);
              }

              /* ===== Y轴控制 ===== */
              filtered_y = filtered_y * (1.0f - Y_FILTER_FACTOR)
                        + ((float)y * Y_FILTER_FACTOR);

              y_error = filtered_y - IMAGE_CENTER_Y;

              if ((filtered_y >= Y_CENTER_MIN) && (filtered_y <= Y_CENTER_MAX))
              {
                  target_angle_y = current_angle_y;
              }
              else
              {
                  target_angle_y += (y_error / IMAGE_CENTER_Y)
                                  * Y_TRACK_STEP_GAIN_DEG
                                  * Y_TRACK_DIRECTION;

                  target_angle_y = Limit_Float(target_angle_y,
                                              SERVO_Y_MIN_ANGLE,
                                              SERVO_Y_MAX_ANGLE);
              }

              /* OLED */
              OLED_ShowString(0, 0, "X:         ");
              OLED_ShowString(0, 2, "Y:         ");
              OLED_ShowString(0, 4, "TRACKING   ");

              sprintf(tx_buffer, "%d", x);
              OLED_ShowString(12, 0, tx_buffer);

              sprintf(tx_buffer, "%d", y);
              OLED_ShowString(12, 2, tx_buffer);

              OLED_Refresh();
						}
					}
        }
    }

    /* =========================================================
     * 5. 云台更新策略
     * =========================================================
     * 如果当前有目标，或者最近一小段时间内刚见过目标，
     * 就继续保持跟随，避免短时漏检造成动作突变。
     */
    if (target_valid)
    {
        /* -----------------------------
         * 5.1 X 轴平滑更新
         * -----------------------------
         * 这里不是一步跳到 target_angle_x，
         * 而是平滑逼近，防止舵机动作过猛。
         */
        current_angle_x = current_angle_x * (1.0f - SERVO_SMOOTH_FACTOR)
                        + target_angle_x * SERVO_SMOOTH_FACTOR;

        /* 如果已经非常接近目标角度，就直接贴上去 */
        if ((current_angle_x > (target_angle_x - SERVO_DEAD_BAND)) &&
            (current_angle_x < (target_angle_x + SERVO_DEAD_BAND)))
        {
            current_angle_x = target_angle_x;
        }

        /* -----------------------------
         * 5.2 Y 轴平滑更新
         * ----------------------------- */
        current_angle_y = current_angle_y * (1.0f - SERVO_SMOOTH_FACTOR)
                        + target_angle_y * SERVO_SMOOTH_FACTOR;

        if ((current_angle_y > (target_angle_y - SERVO_DEAD_BAND)) &&
            (current_angle_y < (target_angle_y + SERVO_DEAD_BAND)))
        {
            current_angle_y = target_angle_y;
        }

        /* -----------------------------
         * 5.3 输出到两个舵机
         * ----------------------------- */
        Servo_SetAngle(&htim2, SERVO_X_CHANNEL, current_angle_x);
        Servo_SetAngle(&htim2, SERVO_Y_CHANNEL, current_angle_y);
    }
else
{
    /* =====================================================
     * NONE 模式：保持静止
     * ===================================================== */
    if (current_target_mode == TARGET_MODE_NONE)
    {
        target_angle_x = current_angle_x;
        target_angle_y = current_angle_y;

        Servo_SetAngle(&htim2, SERVO_X_CHANNEL, current_angle_x);
        Servo_SetAngle(&htim2, SERVO_Y_CHANNEL, current_angle_y);
    }
    else
    {
        /* =====================================================
         * 搜索模式（主动寻找目标）
         * ===================================================== */

        if (!target_valid && current_target_mode != TARGET_MODE_NONE)
        {
            if (!search_mode)
            {
                search_mode = 1;
                target_switch_tick = HAL_GetTick();
            }
        }

        if (search_mode)
        {
            uint32_t now_tick = HAL_GetTick();
            uint32_t update_interval = SEARCH_UPDATE_MS;
            float step_deg = SEARCH_STEP_DEG;
            float search_left_limit = SEARCH_X_LEFT_ANGLE;
            float search_right_limit = SEARCH_X_RIGHT_ANGLE;

            if ((now_tick - target_switch_tick) <= SEARCH_START_DELAY_MS)
            {
                target_angle_x = current_angle_x;
                target_angle_y = current_angle_y;

                Servo_SetAngle(&htim2, SERVO_X_CHANNEL, current_angle_x);
                Servo_SetAngle(&htim2, SERVO_Y_CHANNEL, current_angle_y);
            }
            else
            {
                if (search_phase == SEARCH_PHASE_LOCAL_RECAPTURE)
                {
                    Update_AdaptiveRecaptureWindow(now_tick);
                    search_left_limit = search_phase1_left_angle;
                    search_right_limit = search_phase1_right_angle;
                    step_deg = SEARCH_PHASE1_STEP_DEG;
                    update_interval = SEARCH_PHASE1_UPDATE_MS;

                    if ((now_tick - search_phase_start_tick) >= SEARCH_PHASE1_TIMEOUT_MS)
                    {
                        search_phase = SEARCH_PHASE_GLOBAL_RECAPTURE;
                    }
                }

                if (search_phase == SEARCH_PHASE_GLOBAL_RECAPTURE)
                {
                    float lost_seconds = 0.0f;

                    if (search_phase_start_tick != 0U)
                    {
                        lost_seconds = (float)(now_tick - search_phase_start_tick) / 1000.0f;
                    }

                    search_phase2_step_deg =
                        SEARCH_PHASE2_STEP_BASE_DEG +
                        (SEARCH_PHASE2_STEP_GAIN_DEG_PER_S * lost_seconds);
                    search_phase2_step_deg = Limit_Float(search_phase2_step_deg,
                                                         SEARCH_PHASE2_STEP_MIN_DEG,
                                                         SEARCH_PHASE2_STEP_MAX_DEG);

                    step_deg = search_phase2_step_deg;
                    update_interval = SEARCH_UPDATE_MS;
                    search_left_limit = SEARCH_PHASE2_LEFT_ANGLE;
                    search_right_limit = SEARCH_PHASE2_RIGHT_ANGLE;
                }

                search_angle_x = Limit_Float(search_angle_x,
                                             search_left_limit,
                                             search_right_limit);

                if ((now_tick - search_last_tick) >= update_interval)
                {
                    search_last_tick = now_tick;

                    search_angle_x += step_deg * search_direction;

                    if (search_angle_x >= search_right_limit)
                    {
                        search_angle_x = search_right_limit;
                        search_direction = -1;
                    }
                    else if (search_angle_x <= search_left_limit)
                    {
                        search_angle_x = search_left_limit;
                        search_direction = 1;
                    }

                    target_angle_x = search_angle_x;
                    target_angle_y = SEARCH_Y_FIXED_ANGLE;

                    current_angle_x = target_angle_x;
                    current_angle_y = target_angle_y;

                    Servo_SetAngle(&htim2, SERVO_X_CHANNEL, current_angle_x);
                    Servo_SetAngle(&htim2, SERVO_Y_CHANNEL, current_angle_y);
                }
            }
        }
    }
}

    /* 搜索/发现目标的自动语音放在状态更新完成后统一处理 */
    Handle_SystemVoice_Update();

    HAL_Delay(SERVO_UPDATE_DELAY_MS);

    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

