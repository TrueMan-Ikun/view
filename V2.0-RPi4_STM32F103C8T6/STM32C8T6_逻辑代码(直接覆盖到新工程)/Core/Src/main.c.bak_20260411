/**
  * @brief GPIO Initialization Function
  * @param None
  * @retval None
  */
static void MX_GPIO_Init(void)
{
  GPIO_InitTypeDef GPIO_InitStruct = {0};
  /* USER CODE BEGIN MX_GPIO_Init_1 */

  /* USER CODE END MX_GPIO_Init_1 */

  /* GPIO Ports Clock Enable */
  __HAL_RCC_GPIOE_CLK_ENABLE();
  __HAL_RCC_GPIOC_CLK_ENABLE();
  __HAL_RCC_GPIOA_CLK_ENABLE();
  __HAL_RCC_GPIOB_CLK_ENABLE();

  /*Configure GPIO pins : PE2 PE3 PE7 PE13
                           PE14 PE15 */
  GPIO_InitStruct.Pin = GPIO_PIN_2|GPIO_PIN_3|GPIO_PIN_7|GPIO_PIN_13
                          |GPIO_PIN_14|GPIO_PIN_15;
  GPIO_InitStruct.Mode = GPIO_MODE_INPUT;
  GPIO_InitStruct.Pull = GPIO_PULLUP;
  HAL_GPIO_Init(GPIOE, &GPIO_InitStruct);

  /*Configure GPIO pins : PC0 PC1 */
  GPIO_InitStruct.Pin = GPIO_PIN_0|GPIO_PIN_1;
  GPIO_InitStruct.Mode = GPIO_MODE_INPUT;
  GPIO_InitStruct.Pull = GPIO_PULLUP;
  HAL_GPIO_Init(GPIOC, &GPIO_InitStruct);

  /* USER CODE BEGIN MX_GPIO_Init_2 */

  /* USER CODE END MX_GPIO_Init_2 */
}

/* USER CODE BEGIN 4 */

/*
 * 函数名：Send_TargetMode_To_OpenMV
 * 功能：把当前目标模式通过 USART2 发给 OpenMV
 *
 * 协议格式：
 * TARGET:0\r\n
 * TARGET:1\r\n
 * TARGET:2\r\n
 * TARGET:3\r\n
 * TARGET:4\r\n
 *
 * 说明：
 * 这里使用 USART2，是因为当前工程里 OpenMV 和 STM32 的通信
 * 就是走 huart2 这一条链路。
 */
void Send_TargetMode_To_OpenMV(uint8_t mode)
{
    char cmd[20];

    sprintf(cmd, "TARGET:%d\r\n", mode);
    HAL_UART_Transmit(&huart2, (uint8_t *)cmd, strlen(cmd), HAL_MAX_DELAY);
}

/*
 * 函数名：Update_TargetMode_Display
 * 功能：在 OLED 上显示当前识别模式
 *
 * 说明：
 * 这里单独封装成函数，后续如果你想改显示样式，
 * 只需要改这里，不用到处改主逻辑。
 */
void Update_TargetMode_Display(uint8_t mode)
{
    OLED_ShowString(0, 6, "MODE:       ");
    OLED_ShowString(36, 6, (char *)target_mode_name[mode]);
    OLED_Refresh();
}

/*
 * 函数名：Are_All_Keys_Released
 * 功能：判断当前五个按键是否都已经松开
 *
 * 说明：
 * 1. 这里统一读取所有按键输入
 * 2. 只有全部恢复为高电平，才允许下一次按键触发
 * 3. 这样可以避免一次物理按压因为持续时间较长而被识别成多次切换
 */
uint8_t Are_All_Keys_Released(void)
{
    if (HAL_GPIO_ReadPin(KEY_VOICE_PORT, KEY_VOICE_PIN) == GPIO_PIN_RESET)
    {
        return 0U;
    }

    if (HAL_GPIO_ReadPin(KEY_PERSON_PORT, KEY_PERSON_PIN) == GPIO_PIN_RESET)
    {
        return 0U;
    }

    if (HAL_GPIO_ReadPin(KEY_BOTTLE_PORT, KEY_BOTTLE_PIN) == GPIO_PIN_RESET)
    {
        return 0U;
    }

    if (HAL_GPIO_ReadPin(KEY_PEN_PORT, KEY_PEN_PIN) == GPIO_PIN_RESET)
    {
        return 0U;
    }

    if (HAL_GPIO_ReadPin(KEY_STAIRS_PORT, KEY_STAIRS_PIN) == GPIO_PIN_RESET)
    {
        return 0U;
    }

    if (HAL_GPIO_ReadPin(KEY_ELEVATOR_PORT, KEY_ELEVATOR_PIN) == GPIO_PIN_RESET)
    {
        return 0U;
    }

    if (HAL_GPIO_ReadPin(KEY_EXTINGUISHER_PORT, KEY_EXTINGUISHER_PIN) == GPIO_PIN_RESET)
    {
        return 0U;
    }

    if (HAL_GPIO_ReadPin(KEY_NONE_PORT, KEY_NONE_PIN) == GPIO_PIN_RESET)
    {
        return 0U;
    }

    return 1U;
}

/*
 * 函数名：Key_Scan_And_Handle
 * 功能：扫描五个按钮，并根据按钮结果切换目标模式
 *
 * 当前映射关系：
 *PC0 -> Toilet
 *PC1 -> Exit
 *PE13 -> Office
 *PE2 -> Stairs
 *PE3 -> Elevator
 *PE7 -> Extinguisher
 *PE14 -> DFPlayer Test
 *PE15 -> None
 *
 * 说明：
 * 1. 当前按钮采用“上拉输入”
 * 2. 所以按下时读到的是 GPIO_PIN_RESET
 * 3. 用统一的消抖时间，防止一次按压触发多次
 */
void Key_Scan_And_Handle(void)
{
    uint32_t now_tick = HAL_GetTick();

    /* 必须先松手，才允许下一次按键触发 */
    if (key_wait_release)
    {
        if (Are_All_Keys_Released())
        {
            key_wait_release = 0U;
        }
        else
        {
            return;
        }
    }

    /* 如果还在消抖时间内，就直接返回 */
    if ((now_tick - key_last_tick) < KEY_DEBOUNCE_MS)
    {
        return;
    }

    /* -----------------------------
     * 0. 按键：DFPlayer Test
     * PE14
     * -----------------------------
     * PE14 当前固定用作语音测试按键，不参与目标模式切换。
     */
    if (HAL_GPIO_ReadPin(KEY_VOICE_PORT, KEY_VOICE_PIN) == GPIO_PIN_RESET)
    {
        key_last_tick = now_tick;
        key_wait_release = 1U;
        Handle_Voice_Test_Key();
        return;
    }

    /* -----------------------------
     * 1. 按键：Toilet
     * PC0
     * ----------------------------- */
    if (HAL_GPIO_ReadPin(KEY_PERSON_PORT, KEY_PERSON_PIN) == GPIO_PIN_RESET)
    {
        current_target_mode = TARGET_MODE_TOILET;
        key_last_tick = now_tick;
        key_wait_release = 1U;
        Reset_SystemVoice_State(1);
        mode_switch_search_only_until_tick = now_tick + VOICE_MODE_SWITCH_SEARCH_ONLY_MS;
        mode_switch_wait_for_first_found = 1;

        Update_TargetMode_Display(current_target_mode);
        Send_TargetMode_To_OpenMV(current_target_mode);

        /* =====================================================
        * 切换目标后：启动搜索流程
        * =====================================================
        * 1. 清除当前目标状态
        * 2. 云台回中
        * 3. 启动搜索模式
        */

        target_valid = 0;                          // 当前没有锁定目标
        search_mode = 1;                           // 进入搜索模式
        target_switch_tick = HAL_GetTick();        // 记录切换时间（用于延时回中）
        Reset_AdaptiveRecaptureState();

        search_angle_x = current_angle_x;         // 从原位置开始扫
        search_direction = Get_SearchDirection_FromError(last_x_error);

        prev_target_valid = 0;
        prev_search_mode = 0;
        return;
    }
    /* -----------------------------
     * 2. 按键：Exit
     * PC1
     * ----------------------------- */
    if (HAL_GPIO_ReadPin(KEY_BOTTLE_PORT, KEY_BOTTLE_PIN) == GPIO_PIN_RESET)
    {
        current_target_mode = TARGET_MODE_EXIT;
        key_last_tick = now_tick;
        key_wait_release = 1U;
        Reset_SystemVoice_State(1);
        mode_switch_search_only_until_tick = now_tick + VOICE_MODE_SWITCH_SEARCH_ONLY_MS;
        mode_switch_wait_for_first_found = 1;

        Update_TargetMode_Display(current_target_mode);
        Send_TargetMode_To_OpenMV(current_target_mode);

        target_valid = 0;
        search_mode = 1;
        target_switch_tick = HAL_GetTick();
        Reset_AdaptiveRecaptureState();

        search_angle_x = current_angle_x;
        search_direction = Get_SearchDirection_FromError(last_x_error);

        prev_target_valid = 0;
        prev_search_mode = 0;
        return;
    }
    /* -----------------------------
     * 3. 按键：Office
     * PE13
     * ----------------------------- */
    if (HAL_GPIO_ReadPin(KEY_PEN_PORT, KEY_PEN_PIN) == GPIO_PIN_RESET)
    {
        current_target_mode = TARGET_MODE_OFFICE;
        key_last_tick = now_tick;
        key_wait_release = 1U;
        Reset_SystemVoice_State(1);
        mode_switch_search_only_until_tick = now_tick + VOICE_MODE_SWITCH_SEARCH_ONLY_MS;
        mode_switch_wait_for_first_found = 1;

        Update_TargetMode_Display(current_target_mode);
        Send_TargetMode_To_OpenMV(current_target_mode);

        target_valid = 0;
        search_mode = 1;
        target_switch_tick = HAL_GetTick();
        Reset_AdaptiveRecaptureState();

        search_angle_x = current_angle_x;
        search_direction = Get_SearchDirection_FromError(last_x_error);

        prev_target_valid = 0;
        prev_search_mode = 0;

        return;
    }
    /* -----------------------------
     * 4. 按键：Stairs
     * PE2
     * ----------------------------- */
    if (HAL_GPIO_ReadPin(KEY_STAIRS_PORT, KEY_STAIRS_PIN) == GPIO_PIN_RESET)
    {
        current_target_mode = TARGET_MODE_STAIRS;
        key_last_tick = now_tick;
        key_wait_release = 1U;
        Reset_SystemVoice_State(1);
        mode_switch_search_only_until_tick = now_tick + VOICE_MODE_SWITCH_SEARCH_ONLY_MS;
        mode_switch_wait_for_first_found = 1;

        Update_TargetMode_Display(current_target_mode);
        Send_TargetMode_To_OpenMV(current_target_mode);

        target_valid = 0;
        search_mode = 1;
        target_switch_tick = HAL_GetTick();
        Reset_AdaptiveRecaptureState();

        search_angle_x = current_angle_x;
        search_direction = Get_SearchDirection_FromError(last_x_error);

        prev_target_valid = 0;
        prev_search_mode = 0;
        return;
    }

    /* -----------------------------
     * 5. 按键：Elevator
     * PE3
     * ----------------------------- */
    if (HAL_GPIO_ReadPin(KEY_ELEVATOR_PORT, KEY_ELEVATOR_PIN) == GPIO_PIN_RESET)
    {
        current_target_mode = TARGET_MODE_ELEVATOR;
        key_last_tick = now_tick;
        key_wait_release = 1U;
        Reset_SystemVoice_State(1);
        mode_switch_search_only_until_tick = now_tick + VOICE_MODE_SWITCH_SEARCH_ONLY_MS;
        mode_switch_wait_for_first_found = 1;

        Update_TargetMode_Display(current_target_mode);
        Send_TargetMode_To_OpenMV(current_target_mode);

        target_valid = 0;
        search_mode = 1;
        target_switch_tick = HAL_GetTick();
        Reset_AdaptiveRecaptureState();

        search_angle_x = current_angle_x;
        search_direction = Get_SearchDirection_FromError(last_x_error);

        prev_target_valid = 0;
        prev_search_mode = 0;
        return;
    }

    /* -----------------------------
     * 6. 按键：Extinguisher
     * PE7
     * ----------------------------- */
    if (HAL_GPIO_ReadPin(KEY_EXTINGUISHER_PORT, KEY_EXTINGUISHER_PIN) == GPIO_PIN_RESET)
    {
        current_target_mode = TARGET_MODE_EXTINGUISHER;
        key_last_tick = now_tick;
        key_wait_release = 1U;
        Reset_SystemVoice_State(1);
        mode_switch_search_only_until_tick = now_tick + VOICE_MODE_SWITCH_SEARCH_ONLY_MS;
        mode_switch_wait_for_first_found = 1;

        Update_TargetMode_Display(current_target_mode);
        Send_TargetMode_To_OpenMV(current_target_mode);

        target_valid = 0;
        search_mode = 1;
        target_switch_tick = HAL_GetTick();
        Reset_AdaptiveRecaptureState();

        search_angle_x = current_angle_x;
        search_direction = Get_SearchDirection_FromError(last_x_error);

        prev_target_valid = 0;
        prev_search_mode = 0;
        return;
    }

    /* -----------------------------
     * 7. 按键：None
     * PE15
     * ----------------------------- */
    if (HAL_GPIO_ReadPin(KEY_NONE_PORT, KEY_NONE_PIN) == GPIO_PIN_RESET)
    {
        current_target_mode = TARGET_MODE_NONE;
        key_last_tick = now_tick;
        key_wait_release = 1U;
        Reset_SystemVoice_State(0);
        mode_found_prompt_played = 1;
        mode_switch_search_only_until_tick = 0U;
        mode_switch_wait_for_first_found = 0U;

        Update_TargetMode_Display(current_target_mode);
        Send_TargetMode_To_OpenMV(current_target_mode);
        Play_ModeSwitch_Voice(current_target_mode);

        /* =====================================================
        * NONE 模式：停止搜索，锁定当前位置
          * ===================================================== */
          target_valid = 0;
          search_mode = 0;
          lost_count = 0;
          Reset_AdaptiveRecaptureState();
          prev_target_valid = 0;
          prev_search_mode = 0;

          /* 把目标角度锁到当前位置，防止继续运动 */
          target_angle_x = current_angle_x;
          target_angle_y = current_angle_y;

          Servo_SetAngle(&htim2, SERVO_X_CHANNEL, current_angle_x);
          Servo_SetAngle(&htim2, SERVO_Y_CHANNEL, current_angle_y);

          return;
      }
}

/*
 * 函数名：Get_SearchDirection_FromError
 * 功能：根据最后一次 X 轴误差，给出搜索起始方向
 *
 * 说明：
 * 1. 误差为正，优先沿当前约定的“正方向”搜索
 * 2. 误差为负，优先沿反方向搜索
 * 3. 如果误差很小，说明方向信息不可靠，回退为默认正方向
 */
int8_t Get_SearchDirection_FromError(float x_error)
{
    if (x_error > SEARCH_DIRECTION_EPSILON_PIXELS)
    {
        return 1;
    }

    if (x_error < (-SEARCH_DIRECTION_EPSILON_PIXELS))
    {
        return -1;
    }

    return 1;
}

/*
 * 函数名：Reset_AdaptiveRecaptureState
 * 功能：重置自适应主动重捕获相关状态
 *
 * 说明：
 * 1. 模式切换、停止识别、重新稳定找到目标时都需要清零
 * 2. 这里只清理搜索阶段和搜索语音标志，不修改 lost_recovery_active
 */
void Reset_AdaptiveRecaptureState(void)
{
    search_phase = SEARCH_PHASE_NONE;
    search_phase_start_tick = 0U;
    search_center_x = current_angle_x;
    search_phase1_left_angle = current_angle_x;
    search_phase1_right_angle = current_angle_x;
    search_phase2_step_deg = SEARCH_PHASE2_STEP_BASE_DEG;
    lost_search_prompt_played = 0U;
}

/*
 * 函数名：Enter_AdaptiveRecapturePhase1
 * 功能：在真正丢失目标后，进入局部快速重捕获阶段
 */
void Enter_AdaptiveRecapturePhase1(uint32_t lost_tick)
{
    search_phase = SEARCH_PHASE_LOCAL_RECAPTURE;
    search_phase_start_tick = lost_tick;
    search_center_x = current_angle_x;
    search_angle_x = current_angle_x;
    search_direction = Get_SearchDirection_FromError(last_x_error);
    search_phase1_left_angle = current_angle_x;
    search_phase1_right_angle = current_angle_x;
    search_phase2_step_deg = SEARCH_PHASE2_STEP_BASE_DEG;
    lost_search_prompt_played = 0U;
    search_last_tick = lost_tick;
}

/*
 * 函数名：Update_AdaptiveRecaptureWindow
 * 功能：根据最后误差和丢失时长，更新阶段 1 的局部搜索窗口
 */
void Update_AdaptiveRecaptureWindow(uint32_t now_tick)
{
    float lost_seconds = 0.0f;
    float error_ratio = 0.0f;
    float amplitude = SEARCH_PHASE1_BASE_AMPLITUDE_DEG;

    if (search_phase_start_tick != 0U)
    {
        lost_seconds = (float)(now_tick - search_phase_start_tick) / 1000.0f;
    }

    error_ratio = ((last_x_error >= 0.0f) ? last_x_error : (-last_x_error)) / IMAGE_CENTER_X;

    amplitude += (SEARCH_PHASE1_ERROR_GAIN_DEG * error_ratio);
    amplitude += (SEARCH_PHASE1_TIME_GAIN_DEG_PER_S * lost_seconds);
    amplitude = Limit_Float(amplitude,
                            SEARCH_PHASE1_MIN_AMPLITUDE_DEG,
                            SEARCH_PHASE1_MAX_AMPLITUDE_DEG);

    search_phase1_left_angle = Limit_Float(search_center_x - amplitude,
                                           SEARCH_X_LEFT_ANGLE,
                                           SEARCH_X_RIGHT_ANGLE);
    search_phase1_right_angle = Limit_Float(search_center_x + amplitude,
                                            SEARCH_X_LEFT_ANGLE,
                                            SEARCH_X_RIGHT_ANGLE);

    if (search_phase1_left_angle > search_phase1_right_angle)
    {
        search_phase1_left_angle = search_phase1_right_angle;
    }
}

/*
 * 函数名：Reset_SystemVoice_State
 * 功能：重置系统语音相关状态
 *
 * 说明：
 * 1. 切换模式时清空待播语音，防止旧模式的状态语音延后插入
 * 2. 同时重置 PE14 测试按键状态，避免测试语音与系统语音互相干扰
 * 3. clear_found_prompt_flag = 1 时，允许新模式重新播报一次“已发现目标”
 */
void Reset_SystemVoice_State(uint8_t clear_found_prompt_flag)
{
    pending_prompt_valid = 0;
    pending_prompt_index = 0U;
    pending_prompt_type = VOICE_PROMPT_TYPE_NONE;
    pending_prompt_tick = 0U;
  system_voice_guard_until_tick = 0U;
  found_prompt_candidate_active = 0;
  found_prompt_candidate_tick = 0U;
  lost_recovery_active = 0;
  lost_search_prompt_played = 0U;
  mode_switch_search_only_until_tick = 0U;
  mode_switch_wait_for_first_found = 0U;

    voice_started = 0;
    voice_paused = 0;

    if (clear_found_prompt_flag)
    {
        mode_found_prompt_played = 0;
    }
}

/*
 * 函数名：Queue_SystemVoice
 * 功能：登记一条待播系统语音
 *
 * 说明：
 * 1. 搜索语音和发现语音共用同一个待播槽
 * 2. 如果搜索语音还没播出，而发现语音先到了，则允许发现语音覆盖搜索语音
 * 3. 不允许搜索语音覆盖已经登记好的发现语音，避免重要提示被降级
 */
void Queue_SystemVoice(uint16_t prompt_index, uint8_t prompt_type, uint32_t due_tick)
{
    if ((prompt_index == 0U) || (prompt_type == VOICE_PROMPT_TYPE_NONE))
    {
        return;
    }

    if (!pending_prompt_valid)
    {
        pending_prompt_valid = 1;
        pending_prompt_index = prompt_index;
        pending_prompt_type = prompt_type;
        pending_prompt_tick = due_tick;
        return;
    }

    if ((pending_prompt_type == VOICE_PROMPT_TYPE_SEARCH) &&
        (prompt_type == VOICE_PROMPT_TYPE_FOUND))
    {
        pending_prompt_index = prompt_index;
        pending_prompt_type = prompt_type;
        pending_prompt_tick = due_tick;
        return;
    }

    if (pending_prompt_type == prompt_type)
    {
        pending_prompt_index = prompt_index;
        pending_prompt_tick = due_tick;
    }
}

/*
 * 函数名：Play_SystemVoice_Now
 * 功能：立即播放系统语音，并刷新语音保护时间
 *
 * 说明：
 * 1. 所有自动播报统一走这里，便于后续替换语音模块
 * 2. 播放系统语音时，会重置 PE14 的测试按键状态机
 */
void Play_SystemVoice_Now(uint16_t prompt_index, uint32_t guard_ms)
{
    if (prompt_index == 0U)
    {
        return;
    }

    DFPlayer_PlayMp3(prompt_index);

    voice_started = 0;
    voice_paused = 0;
    system_voice_guard_until_tick = HAL_GetTick() + guard_ms;
}

/*
 * 函数名：Get_TargetMode_VoicePrompt
 * 功能：获取当前目标模式对应的名称语音文件编号
 *
 * 说明：
 * 1. Toilet / Exit / Office 对应的是“这是什么”类语音
 * 2. None 对应“已停止识别”
 * 3. 后续如果更换语音文件编号，优先修改配置宏即可
 */
uint16_t Get_TargetMode_VoicePrompt(uint8_t mode)
{
    uint16_t prompt_index = 0U;

    switch (mode)
    {
        case TARGET_MODE_TOILET:
            prompt_index = DFPLAYER_MODE_TOILET_MP3_INDEX;
            break;

        case TARGET_MODE_EXIT:
            prompt_index = DFPLAYER_MODE_EXIT_MP3_INDEX;
            break;

        case TARGET_MODE_OFFICE:
            prompt_index = DFPLAYER_MODE_OFFICE_MP3_INDEX;
            break;

        case TARGET_MODE_STAIRS:
            prompt_index = DFPLAYER_MODE_STAIRS_MP3_INDEX;
            break;

        case TARGET_MODE_ELEVATOR:
            prompt_index = DFPLAYER_MODE_ELEVATOR_MP3_INDEX;
            break;

        case TARGET_MODE_EXTINGUISHER:
            prompt_index = DFPLAYER_MODE_EXTINGUISHER_MP3_INDEX;
            break;

        case TARGET_MODE_NONE:
            prompt_index = DFPLAYER_MODE_NONE_MP3_INDEX;
            break;

        default:
            break;
    }

    return prompt_index;
}

/*
 * 函数名：Play_ModeSwitch_Voice
 * 功能：播放当前模式对应的名称语音
 *
 * 说明：
 * 1. None 模式切换时会立即调用这里，播报“已停止识别”
 * 2. Toilet / Exit / Office 三种模式不再在按键按下时立即播报
 * 3. 这三种模式的名称语音改为在“已发现目标”之后再播
 */
void Play_ModeSwitch_Voice(uint8_t mode)
{
    Play_SystemVoice_Now(Get_TargetMode_VoicePrompt(mode), VOICE_MODE_GUARD_MS);
}

/*
 * 函数名：Handle_SystemVoice_Update
 * 功能：根据搜索/识别状态更新系统语音
 *
 * 说明：
 * 1. 这里只做“边沿触发 + 待播管理”，不直接参与目标识别和舵机控制
 * 2. 搜索语音只在进入搜索状态时登记一次
 * 3. “已发现目标”语音需要先通过一段时间的稳定确认，避免误判时直接播报
 * 4. 发现语音在每个模式周期内只允许播放一次
 * 5. 正常首次发现：先播“已发现目标”，再播当前目标对应的名称语音
 * 6. 丢失后找回：不再播“正在搜索目标”和“已发现目标”，只播目标名称
 */
void Handle_SystemVoice_Update(void)
{
    uint32_t now_tick = HAL_GetTick();
    uint32_t due_tick = now_tick;
    uint8_t mode_switch_guard_active =
        ((int32_t)(mode_switch_search_only_until_tick - now_tick) > 0) ? 1U : 0U;

    if (current_target_mode == TARGET_MODE_NONE)
    {
        pending_prompt_valid = 0;
        pending_prompt_index = 0U;
        pending_prompt_type = VOICE_PROMPT_TYPE_NONE;
        pending_prompt_tick = 0U;
        found_prompt_candidate_active = 0;
        found_prompt_candidate_tick = 0U;
        lost_recovery_active = 0;
        lost_search_prompt_played = 0U;
        mode_switch_search_only_until_tick = 0U;
        mode_switch_wait_for_first_found = 0U;

        prev_search_mode = search_mode;
        prev_target_valid = target_valid;
        return;
    }

    if (!target_valid)
    {
        found_prompt_candidate_active = 0;
        found_prompt_candidate_tick = 0U;

        if (pending_prompt_valid &&
            (pending_prompt_type == VOICE_PROMPT_TYPE_FOUND))
        {
            pending_prompt_valid = 0;
            pending_prompt_index = 0U;
            pending_prompt_type = VOICE_PROMPT_TYPE_NONE;
            pending_prompt_tick = 0U;
        }
    }

    if (pending_prompt_valid &&
        (pending_prompt_type == VOICE_PROMPT_TYPE_SEARCH) &&
        target_valid &&
        !mode_switch_guard_active)
    {
        pending_prompt_valid = 0;
        pending_prompt_index = 0U;
        pending_prompt_type = VOICE_PROMPT_TYPE_NONE;
        pending_prompt_tick = 0U;
    }

    if ((!prev_search_mode) && search_mode && !target_valid)
    {
        if (lost_recovery_active)
        {
            if ((search_phase == SEARCH_PHASE_LOCAL_RECAPTURE) &&
                (!lost_search_prompt_played))
            {
                if ((int32_t)(system_voice_guard_until_tick - due_tick) > 0)
                {
                    due_tick = system_voice_guard_until_tick;
                }

                Queue_SystemVoice(DFPLAYER_SEARCHING_MP3_INDEX,
                                  VOICE_PROMPT_TYPE_SEARCH,
                                  due_tick);
                lost_search_prompt_played = 1U;
            }
        }
        else
        {
            if ((int32_t)(system_voice_guard_until_tick - due_tick) > 0)
            {
                due_tick = system_voice_guard_until_tick;
            }

            Queue_SystemVoice(DFPLAYER_SEARCHING_MP3_INDEX,
                              VOICE_PROMPT_TYPE_SEARCH,
                              due_tick);
        }
    }

    if (mode_switch_guard_active)
    {
        found_prompt_candidate_active = 0;
        found_prompt_candidate_tick = 0U;
    }
    else if ((!found_prompt_candidate_active) &&
             (((!prev_target_valid) && target_valid) ||
              (mode_switch_wait_for_first_found && target_valid)) &&
             (!mode_found_prompt_played || lost_recovery_active))
    {
        found_prompt_candidate_active = 1;
        found_prompt_candidate_tick = now_tick;
    }

    if (found_prompt_candidate_active && target_valid &&
        (!mode_found_prompt_played || lost_recovery_active))
    {
        if ((now_tick - found_prompt_candidate_tick) >= VOICE_FOUND_CONFIRM_MS)
        {
            found_prompt_candidate_active = 0;
            found_prompt_candidate_tick = 0U;
            mode_switch_wait_for_first_found = 0U;
            due_tick = now_tick;

            if ((int32_t)(system_voice_guard_until_tick - due_tick) > 0)
            {
                due_tick = system_voice_guard_until_tick;
            }

            if (lost_recovery_active)
            {
                if ((int32_t)(due_tick - now_tick) > 0)
                {
                    Queue_SystemVoice(Get_TargetMode_VoicePrompt(current_target_mode),
                                      VOICE_PROMPT_TYPE_TARGET,
                                      due_tick);
                }
                else
                {
                    pending_prompt_valid = 0;
                    pending_prompt_index = 0U;
                    pending_prompt_type = VOICE_PROMPT_TYPE_NONE;
                    pending_prompt_tick = 0U;

                    Play_SystemVoice_Now(Get_TargetMode_VoicePrompt(current_target_mode),
                                         VOICE_STATUS_GUARD_MS);
                }

                lost_recovery_active = 0;
            }
            else
            {
                if ((int32_t)(due_tick - now_tick) > 0)
                {
                    Queue_SystemVoice(DFPLAYER_TARGET_FOUND_MP3_INDEX,
                                      VOICE_PROMPT_TYPE_FOUND,
                                      due_tick);
                }
                else
                {
                    pending_prompt_valid = 0;
                    pending_prompt_index = 0U;
                    pending_prompt_type = VOICE_PROMPT_TYPE_NONE;
                    pending_prompt_tick = 0U;

                    Play_SystemVoice_Now(DFPLAYER_TARGET_FOUND_MP3_INDEX,
                                         VOICE_STATUS_GUARD_MS);
                    mode_found_prompt_played = 1;
                    Queue_SystemVoice(Get_TargetMode_VoicePrompt(current_target_mode),
                                      VOICE_PROMPT_TYPE_TARGET,
                                      HAL_GetTick() + VOICE_TARGET_PROMPT_DELAY_MS);
                }
            }
        }
    }

    if (pending_prompt_valid)
    {
        if ((pending_prompt_type == VOICE_PROMPT_TYPE_SEARCH) && target_valid)
        {
            pending_prompt_valid = 0;
            pending_prompt_index = 0U;
            pending_prompt_type = VOICE_PROMPT_TYPE_NONE;
            pending_prompt_tick = 0U;
        }
        else if ((int32_t)(now_tick - pending_prompt_tick) >= 0)
        {
            uint16_t prompt_index = pending_prompt_index;
            uint8_t prompt_type = pending_prompt_type;

            pending_prompt_valid = 0;
            pending_prompt_index = 0U;
            pending_prompt_type = VOICE_PROMPT_TYPE_NONE;
            pending_prompt_tick = 0U;

            Play_SystemVoice_Now(prompt_index, VOICE_STATUS_GUARD_MS);

            if (prompt_type == VOICE_PROMPT_TYPE_FOUND)
            {
                mode_found_prompt_played = 1;
                Queue_SystemVoice(Get_TargetMode_VoicePrompt(current_target_mode),
                                  VOICE_PROMPT_TYPE_TARGET,
                                  HAL_GetTick() + VOICE_TARGET_PROMPT_DELAY_MS);
            }
        }
    }

    prev_search_mode = search_mode;
    prev_target_valid = target_valid;
}

/*
 * 函数名：Handle_Voice_Test_Key
 * 功能：处理 PE14 语音测试按键的状态机
 *
 * 状态规则：
 * 1. 首次按下 -> 播放测试音频
 * 2. 第二次按下 -> 暂停
 * 3. 第三次按下 -> 继续
 *
 * 说明：
 * 1. 当前只做测试版，不与目标模式和跟随逻辑耦合。
 * 2. 测试音频默认复用厕所模式语音文件，便于单独验证 DFPlayer 链路。
 * 后续如果要扩展系统语音提示，优先从这里的业务调用入口开始整理即可。
 */
void Handle_Voice_Test_Key(void)
{
    if (!voice_started)
    {
        DFPlayer_PlayMp3(DFPLAYER_TEST_MP3_INDEX);
        voice_started = 1;
        voice_paused = 0;
        return;
    }

    if (!voice_paused)
    {
        DFPlayer_Pause();
        voice_paused = 1;
    }
    else
    {
        DFPlayer_Resume();
        voice_paused = 0;
    }
}

float Limit_Float(float value, float min, float max)
{
    if (value < min) return min;
    if (value > max) return max;
    return value;
}

void Servo_SetAngle(TIM_HandleTypeDef *htim, uint32_t channel, float angle)
{
    float pulse;

    /* 统一做“逻辑角度 -> PWM 脉宽”映射。
     * 以后如果换舵机，优先修改配置区里的 SERVO_PULSE_MIN_US / SERVO_PULSE_MAX_US。
     */

    // 先限制在 0~180 度
    if (angle < 0.0f) angle = 0.0f;
    if (angle > SERVO_FULL_ANGLE_DEG) angle = SERVO_FULL_ANGLE_DEG;

    // 先用更保守的 1000~2000us 测试
    pulse = SERVO_PULSE_MIN_US +
            (angle / SERVO_FULL_ANGLE_DEG) * (SERVO_PULSE_MAX_US - SERVO_PULSE_MIN_US);

    __HAL_TIM_SET_COMPARE(htim, channel, (uint16_t)pulse);
}

void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
{
    if (huart->Instance == USART2)
    {
        if (rx_data != '\r' && rx_data != '\n')
        {
            if (rx_index < sizeof(rx_buffer) - 1)
            {
                rx_buffer[rx_index++] = rx_data;
            }
        }
        else
        {
            if (rx_index > 0)   // 防止连续收到 \r\n 时空触发
            {
                rx_buffer[rx_index] = '\0';
                rx_index = 0;
                uart2_received_flag = 1;
            }
        }

        HAL_UART_Receive_IT(&huart2, &rx_data, 1);
    }
}


